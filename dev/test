#!/bin/bash
#
# Runs the full dotfiles setup inside a container.
# Output is captured to dev/.output/ with a timestamped filename.
#
set -o nounset -o errexit -o pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
IMAGE_NAME="dotfiles-dev"
TIMESTAMP="$(date +%Y-%m-%dT%H%M%S)"
OUTPUT_DIR="$REPO_DIR/dev/.output"
LOG_FILE="$OUTPUT_DIR/$TIMESTAMP.log"

mkdir -p "$OUTPUT_DIR"

dev/build

echo "Running test container..."
echo "Log file: $LOG_FILE"

set +o errexit
SSH_KEY="$HOME/.ssh/id_ed25519"
if [ ! -f "$SSH_KEY" ]; then
  echo "Error: SSH key not found at $SSH_KEY"
  exit 1
fi

docker run --platform linux/amd64 --rm -t \
  -e IN_CONTAINER=true \
  -v "$REPO_DIR:/home/debian/dotfiles" \
  -v "$SSH_KEY:/home/debian/.ssh/id_ed25519:ro" \
  "$IMAGE_NAME" \
  bash -c 'ssh-keyscan -t ed25519 github.com >> ~/.ssh/known_hosts 2>/dev/null && bash ~/dotfiles/setup' 2>&1 | tee "$LOG_FILE"
EXIT_CODE=${PIPESTATUS[0]}
set -o errexit

echo ""
if [ $EXIT_CODE -eq 0 ]; then
  echo "Test completed successfully."
else
  echo "Test completed with exit code $EXIT_CODE (some tasks may have failed)."
fi
echo "Full output saved to: $LOG_FILE"
exit $EXIT_CODE
