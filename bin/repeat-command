#!/usr/bin/env bash
set -euo pipefail
#
# Repeatedly runs a command, multiple times.
#

usage() {
  echo "Usage: repeat-command -n <number> <command> [args...]" >&2
  exit 1
}

if [[ $# -lt 3 ]]; then
  usage
fi

if [[ "$1" != "-n" ]]; then
  usage
fi

shift
count="$1"
shift

if ! [[ "$count" =~ ^[1-9][0-9]*$ ]]; then
  echo "Error: repetition count must be a positive integer" >&2
  usage
fi

if [[ $# -eq 0 ]]; then
  usage
fi

timestamp() {
  python3 -c "from datetime import datetime; print(datetime.now().strftime('%Y-%m-%dT%H-%M-%S.%f')[:23])"
}

log_dir="$HOME/.local/log/repeat-command"
mkdir -p "$log_dir"

log_file="$log_dir/$(timestamp).log"
echo "Log: $log_file"
echo ""
echo "Command: $*" | tee -a "$log_file"
echo "" | tee -a "$log_file"

for i in $(seq 1 "$count"); do
  if [[ "$i" -gt 1 ]]; then
    echo "" | tee -a "$log_file"
  fi
  echo "[$(timestamp)] === Run $i/$count ===" | tee -a "$log_file"
  rc=0
  { time "$@"; } 2>&1 | tee -a "$log_file" || rc=${PIPESTATUS[0]}
  if [[ "$rc" -ne 0 ]]; then
    echo "" | tee -a "$log_file"
    echo "---" | tee -a "$log_file"
    echo "[$(timestamp)] Failed on attempt $i" | tee -a "$log_file"
    exit "$rc"
  fi
done

echo "" | tee -a "$log_file"
echo "---" | tee -a "$log_file"
echo "[$(timestamp)] All $count runs succeeded" | tee -a "$log_file"
